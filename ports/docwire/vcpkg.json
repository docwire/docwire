{
	"name": "docwire",
	"version-string": "latest",
	"description": "Data processing library/SDK. Parses DOC, XLS, XLSB, PPT, RTF, ODF (ODT, ODS, ODP), OOXML (DOCX, XLSX, PPTX), iWork (PAGES, NUMBERS, KEYNOTE), ODFXML (FODP, FODS, FODT), PST, OST and more. Contains embedded OCR engine and CLI utiity.",
	"license": "AGPL-3.0-only OR LicenseRef-DocWire-Commercial",
	"features":
	{
		"asan":
		{
			"description": "Enable address sanitizer in debug build"
		},
		"tsan":
		{
			"description": "Enable thread sanitizer in debug build"
		},
		"tests":
		{
			"description": "Enable automatic tests"
		},
		"memcheck":
		{
			"description": "Enable valgrind memcheck in automatic tests"
		},
		"helgrind":
		{
			"description": "Enable valgrind helgrind in automatic tests"
		},
		"callgrind":
		{
			"description": "Enable valgrind callgrind in automatic tests"
		},
		"local-ai":
		{
			"description": "Enable local AI runtime",
			"dependencies": [
			"ctranslate2",
			"sentencepiece",
			"multilingual-e5-small-ct2-int8",
			"flan-t5-large-ct2-int8"
			]
	    },
		"llama-engine":
		{
			"description": "Enable GGUF-based LLM inference (llama.cpp)",
			"dependencies": [
			{ "name": "docwire", "features": ["local-ai"] },
			"llama-cpp"
			]
		},
    	"llama-granite":
		{
			"description": "Install IBM Granite 4.0 1B Q8_0 GGUF model",
			"dependencies": [
			{ "name": "docwire", "features": ["llama-engine"] },
			"granite-4-1b-q8-0"
			]
		}
	},
	"dependencies": [
		{
			"name": "vcpkg-cmake",
			"host": true
		},
		{
			"name": "vcpkg-cmake-config",
			"host": true
		},
		{
			"name": "libcharsetdetect"
		},
		{
			"name": "boost-callable-traits"
		},
		{
			"name": "boost-filesystem"
		},
		{
			"name": "boost-dll"
		},
		{
			"name": "boost-json"
		},
		{
			"name": "boost-program-options"
		},
		{
			"name": "cpp-httplib",
			"features": ["openssl"]
		},
		{
			"name": "magic-enum"
		},
		{
			"name": "pdfium"
		},
		{
			"name": "minizip"
		},
		{
			"name": "lexbor"
		},
		{
			"name": "tesseract"
		},
		{
			"name": "libbfio"
		},
		{
			"name": "libiconv"
		},
		{
			"name": "libpff-unix",
			"platform": "!windows"
		},
		{
			"name": "libpff",
			"platform": "windows"
		},
		{
			"name": "mailio"
		},
		{
			"name": "gtest"
		},
		{
			"name": "tessdata-fast"
		},
		{
			"name": "rapidfuzz-cpp"
		},
		{
			"name": "aklomp-base64"
		},
		{
			"name": "libmagic"
		},
		{
			"name": "libxml2"
		}
	]
}
